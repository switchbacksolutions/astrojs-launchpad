# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# Public site URL — used in sitemap and RSS feed
# Must match the `site` value in astro.config.mjs
PUBLIC_SITE_URL=https://example.com

# Site metadata
PUBLIC_SITE_TITLE="My Astro Blog"
PUBLIC_SITE_DESCRIPTION="A personal blog built with Astro"

# Analytics (optional)
# Set PUBLIC_GA_MEASUREMENT_ID to enable Google Analytics (format: G-XXXXXXXXXX).
# Also set this variable in Netlify → Site settings → Environment variables.
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
